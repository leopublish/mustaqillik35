# ── Backend (Django) ─────────────────────────────────────────────────────────
# Copy this file to backend/.env for local development
# On Railway, set these as environment variables in the service settings

DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=your-backend-service.railway.app

# Provided automatically by Railway PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Provided automatically by Railway Redis plugin (needed for Celery)
REDIS_URL=redis://default:password@host:6379

# CORS — set to your frontend Railway domain
CORS_ALLOWED_ORIGINS=https://your-frontend-service.railway.app

# Optional: Sentry error tracking
# SENTRY_DSN=https://...@sentry.io/...

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
# Set these in the frontend service on Railway

NEXT_PUBLIC_API_URL=https://your-backend-service.railway.app
NEXT_TELEMETRY_DISABLED=1
